# App Info
PROJECT_NAME="Topo-Learn-Agent"
VERSION="1.0.0"

# Postgres Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=topo_learning
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# AI API Keys
GEMINI_API_KEY=your_google_gemini_api_key_here

# S3 Storage (AWS / Cloudflare R2 / MinIO)
S3_ENDPOINT_URL=your_s3_endpoint_url_here
S3_ACCESS_KEY=your_s3_access_key_here
S3_SECRET_KEY=your_s3_secret_key_here
S3_BUCKET_NAME=your_s3_bucket_name_here
S3_PUBLIC_DOMAIN=your_s3_public_domain_here

# Security
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,https://3000-01km48rarxc5z15nx1mndw1rw6.cloudspaces.litng.ai